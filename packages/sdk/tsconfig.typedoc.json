{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "forceConsistentCasingInFileNames": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["node"]
  },
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/manual.ts",
    "src/wasm/manual-bindings.ts"
  ]
}
